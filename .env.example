# ─────────────────────────────────────────────────────────────
#  schedule-assistant-ai 환경 변수 예시
#  이 파일을 복사해 .env.local 을 만들고 실제 값을 입력하세요.
#  .env.local 은 .gitignore 에 포함되어 있어 git에 올라가지 않습니다.
# ─────────────────────────────────────────────────────────────

# Google OAuth credentials (GCP Console → 데스크톱 앱 타입)
# bun run build 시 Next.js 정적 번들에 포함됩니다.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=여기에_Client_ID_입력.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=여기에_Client_Secret_입력

# Microsoft OAuth credentials (Azure Portal → 앱 등록 → 클라이언트 암호)
# bun run build 시 Next.js 정적 번들에 포함됩니다.
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=여기에_Application_ID_입력
NEXT_PUBLIC_MICROSOFT_CLIENT_SECRET=여기에_Client_Secret_입력

# Claude API (앱 설정 화면에서도 입력 가능, 개발 테스트용)
# NEXT_PUBLIC_DEV_ANTHROPIC_KEY=sk-ant-...
